@page "/addphoto"
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.Processing
@inject MongoDBPhotoService PhotoService
@inject CloudflareR2Service CloudflareR2Service
@inject IWebHostEnvironment Env
@inject NavigationManager Navigation
@* @inject IPhotoFormService AddPhotoFormService not needed anymore *@

<PageTitle>Add Photo</PageTitle>

<div class="mb-3">
    <h3>Add Photo</h3>

    <PhotoForm Model="@newPhoto" OnValidSubmit="InsertPhoto" OnChange="HandleFileSelected" IsProcessing="@isAdding" FormName="AddPhotoForm" />
</div>

@code {
    private Photo newPhoto = new();
    private bool isAdding;

    private Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        // the form component already updated the `newPhoto` model,
        // so just log or perform any additional bookkeeping here.
        Console.WriteLine($"PhotoForm raised OnChange, current file: {newPhoto.FileName}");
        return Task.CompletedTask;
    }

    private async Task InsertPhoto()
    {
        isAdding = true;
        Console.WriteLine($"Title: {newPhoto.Title}");
        Console.WriteLine($"Name: {newPhoto.FileName}");

        if (!string.IsNullOrWhiteSpace(newPhoto.FileName) && !string.IsNullOrWhiteSpace(newPhoto.Title))
        {
            await PhotoService.AddAsync(newPhoto);
            Console.WriteLine("Photo added to MongoDB");
            
            await CloudflareR2Service.PutObject(newPhoto);
            Console.WriteLine("Photo added to Cloudflare");            
        }
        else
        {
            Console.WriteLine("Missing file or title");
        }

        Navigation.NavigateTo("/");
        isAdding = false;
    }
}