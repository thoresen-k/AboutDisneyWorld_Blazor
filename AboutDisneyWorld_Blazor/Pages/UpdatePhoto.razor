@page "/updatephoto/{id}"
@using ImageSharp = SixLabors.ImageSharp 
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.Processing
@inject MongoDBPhotoService PhotoService
@inject CloudflareR2Service CloudflareR2Service
@inject IWebHostEnvironment Env
@inject NavigationManager Navigation

<PageTitle>Update Photo</PageTitle>

<div class="mb-3">
    <h3>Update Photo</h3>

    <PhotoForm Model="@photo" OnValidSubmit="EditPhoto" IsProcessing="@isEditing" FormName="EditPhotoForm" />
</div>

@code {
    private Photo photo = new();
    private Photo origPhoto = new();
    private string? previewImageUrl;
    bool isEditing = false;

    [Parameter]
    public string id { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine($"Photo ID from route: {id}");
        // You can use 'id' to fetch photo details from your service

        (Photo fullPhoto, bool success) = await PhotoService.GetPhotoByIdAsync(id);
        if(success){
            photo = ClonePhoto(fullPhoto);
            origPhoto = ClonePhoto(fullPhoto);
            previewImageUrl = photo.ImageSrc;
        }
    }

    private static Photo ClonePhoto(Photo source) => new()
    {
        ID = source.ID,
        FileName = source.FileName,
        Title = source.Title,
        Caption = source.Caption,
        ImageData = source.ImageData,
        PreviewData = source.PreviewData,
        ContentType = source.ContentType,
        ImageSrc = source.ImageSrc,
        Date = source.Date
    };

    private async Task EditPhoto()
    {
        isEditing = true;
        Console.WriteLine($"Title: {photo.Title}");
        Console.WriteLine($"Name: {photo.FileName}");

        if (!string.IsNullOrWhiteSpace(photo.FileName) && !string.IsNullOrWhiteSpace(photo.Title))
        {
            if (!string.IsNullOrWhiteSpace(origPhoto.FileName) && !string.Equals(origPhoto.FileName, photo.FileName, StringComparison.OrdinalIgnoreCase))
            {
                await CloudflareR2Service.DeleteObject(origPhoto);
                Console.WriteLine(value: $"Deleted original photo from Cloudflare: {origPhoto.FileName}");

                await CloudflareR2Service.PutObject(photo);
                Console.WriteLine(value: $"Uploaded new photo to Cloudflare: {origPhoto.FileName}");
            }

            await PhotoService.UpdateAsync(photo);
            Console.WriteLine("Photo updated in MongoDB");
        }
        else
        {
            Console.WriteLine("Missing file or title");
        }

        Navigation.NavigateTo("/");
        isEditing = false;
    }
}