@page "/updatephoto/{id}"
@using ImageSharp = SixLabors.ImageSharp 
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.Processing
@inject MongoDBPhotoService PhotoService
@inject IWebHostEnvironment Env
@inject NavigationManager Navigation

<PageTitle>Update Photo</PageTitle>

<div class="mb-3">
    <h3>Update Photo</h3>

    <PhotoForm Model="@photo" OnValidSubmit="EditPhoto" IsProcessing="@isEditing" FormName="EditPhotoForm" />
</div>

@code {
    private Photo photo = new();
    private string? previewImageUrl;
    bool isEditing = false;

    [Parameter]
    public string id { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine($"Photo ID from route: {id}");
        // You can use 'id' to fetch photo details from your service

        (Photo fullPhoto, bool success) = await PhotoService.GetPhotoByIdAsync(id);
        if(success){
            photo = fullPhoto;
            previewImageUrl = photo.ImageSrc;
        }
    }

    private async Task EditPhoto()
    {
        isEditing = true;
        Console.WriteLine($"Title: {photo.Title}");
        Console.WriteLine($"Name: {photo.FileName}");

        if (!string.IsNullOrWhiteSpace(photo.FileName) && !string.IsNullOrWhiteSpace(photo.Title))
        {
            await PhotoService.UpdateAsync(photo);
            Console.WriteLine("Photo updated in MongoDB");
        }
        else
        {
            Console.WriteLine("Missing file or title");
        }

        Navigation.NavigateTo("/");
        isEditing = false;
    }
}